# Sidecar Configuration

# Environment
NODE_ENV=development

# Database (PostgreSQL on port 5898)
DATABASE_URL=postgresql://postgres:postgres@localhost:5898/sidecar
DB_HOST=localhost
DB_PORT=5898
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=sidecar

# API Configuration
PORT=5050

# Client URL
CLIENT_URL=http://localhost:3007
DOMAIN=http://localhost:5050

# Security
JWT_SECRET=change-me-in-production
ENCRYPTION_KEY=change-me-in-production

# Python Worker
WORKER_URL=http://localhost:9000

# A2A Server Configuration
MIN_A2A_PORT=9997
MAX_A2A_PORT=10100

# Watsonx Orchestrate (configure when needed)
WO_DEVELOPER_EDITION_SOURCE=myibm
WO_ENTITLEMENT_KEY=
WATSONX_APIKEY=
WATSONX_SPACE_ID=

# Logging
LOG_LEVEL=INFO
DEBUG=true