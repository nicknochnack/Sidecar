{
  "port": 5050,
  "worker": {
    "url": "http://localhost:9000"
  },
  "a2a": {
    "minPort": 9997,
    "maxPort": 10100
  },
  "jwt": {
    "expiresIn": "7d"
  },
  "throttle": {
    "api": {
      "max": 1000,
      "windowMs": 3600000,
      "headers": true,
      "message": "Too many API calls from this IP, please try again soon."
    },
    "auth": {
      "max": 50,
      "windowMs": 900000,
      "headers": true,
      "message": "Too many authentication attempts."
    },
    "orchestrate": {
      "max": 30,
      "windowMs": 60000,
      "headers": true,
      "message": "Too many orchestrate commands."
    }
  }
}